        "required_fields": ["prediction", "probability_up", "features"],
        "optional_fields": ["parents", "children", "propagation_chain"],
        "score_boost_if": ["has_parent_contributions", "has_tau_values"]
      }
    },
    "predict": {
      "primary_endpoint": "/causal_graph/{ticker}/multi-step-prediction",
      "fallback_endpoints": ["/causal_graph/{ticker}/prediction"],
      "parameter_mapping": {
        "target_node": "ticker",
        "horizon_hours": "lookahead_hours",
        "features_limit": "limit"
      }
    },
    "path": {
      "primary_endpoint": "/graph_stats/nodes_connection",
      "parameter_mapping": {
        "source_node": "from",
        "target_node": "to",
        "max_depth": "depth"
      }
    },
    "explain": {
      "primary_endpoint": "/causal_graph/{ticker}/prediction",
      "parameter_mapping": {
        "target_node": "ticker",
        "explanation_type": "response_format"
      }
    },
    "attest": {
      "primary_endpoint": "/causal_graph/batch/predictions",
      "parameter_mapping": {
        "nodes": "tickers",
        "comparison_type": "analysis_mode"
      }
    }
  },
